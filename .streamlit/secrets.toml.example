# Exemple de secrets pour le déploiement Streamlit Cloud.
# Sur Streamlit Community Cloud : Settings > Secrets, collez le contenu (sans .example).
# En local : copiez ce fichier en .streamlit/secrets.toml et remplissez la clé.

# Clé API Mistral (nécessaire uniquement pour la comparaison Ministral dans l'onglet Prédiction)
MISTRAL_API_KEY = "votre_cle_api_mistral_ici"
